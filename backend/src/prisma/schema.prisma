// src/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// -----------------------------------------------------------------------------
// 1. USERS & AUTHENTICATION
// -----------------------------------------------------------------------------
model User {
  id            String   @id @default(uuid())
  firebaseUid   String   @unique // NEW: The true Google OAuth2 ID
  email         String   @unique
  name          String
  passwordHash  String?  // UPDATED: Optional, because Google handles security
  role          Role     @default(USER)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  courseAccess        CourseAccess[]
  webinarAccess       WebinarAccess[]      
  subscription        UserSubscription?    
  orders              Order[]
  
  // FIXED: Added missing relation for Retreat Applications
  retreatApplications RetreatApplication[]
  groupRequests       GroupDiscountRequest[]
}

enum Role {
  USER
  ADMIN
}

// -----------------------------------------------------------------------------
// 2. COURSES (Lifetime Access)
// -----------------------------------------------------------------------------

enum CourseCategory {
  Practices
  Scriptures
}

model Course {
  id            String         @id @default(uuid())
  title         String
  description   String         @db.Text
  category      CourseCategory 
  priceInr      Float  
  priceUsd      Float  
  isPublished   Boolean        @default(false)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  videos        CourseVideo[]
  accessLedger  CourseAccess[]
}

model CourseVideo {
  id            String   @id @default(uuid())
  courseId      String
  title         String
  description   String?  @db.Text
  videoUrlR2    String   
  orderIndex    Int      
  
  course        Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

model CourseAccess {
  id            String   @id @default(uuid())
  userId        String
  courseId      String
  orderId       String   @unique 
  purchasedAt   DateTime @default(now())

  user          User     @relation(fields: [userId], references: [id])
  course        Course   @relation(fields: [courseId], references: [id])

  @@unique([userId, courseId]) 
}

// -----------------------------------------------------------------------------
// 3. WEBINARS (One-Time Access or Redeemed via Credits)
// -----------------------------------------------------------------------------
model Webinar {
  id            String   @id @default(uuid())
  title         String
  description   String?  @db.Text
  zoomLink      String   
  minPriceInr   Float    // UPDATED: Allows "Pay What You Want" above minimum
  minPriceUsd   Float
  scheduledFor  DateTime
  imageUrl    String?
  createdAt     DateTime @default(now())

  accessLedger  WebinarAccess[]
}

model WebinarAccess {
  id            String   @id @default(uuid())
  userId        String
  webinarId     String
  orderId       String?  @unique // UPDATED: Optional because they might use a subscription credit instead of buying directly
  purchasedAt   DateTime @default(now())

  user          User     @relation(fields: [userId], references: [id])
  webinar       Webinar  @relation(fields: [webinarId], references: [id])

  @@unique([userId, webinarId]) 
}

// -----------------------------------------------------------------------------
// 4. DAILY SESSIONS & SUBSCRIPTIONS (Credit-Based)
// -----------------------------------------------------------------------------
model DailySession {
  id            String   @id @default(uuid())
  title         String   @default("Daily Live Session")
  zoomLink      String   
  date          DateTime 
  createdAt     DateTime @default(now())
}

model SubscriptionPlan {
  id              String   @id @default(uuid())
  name            String   // e.g., "Monthly Pro", "Quarterly Elite"
  durationDays    Int      // e.g., 30, 90
  webinarCredits  Int      // NEW: How many free Sunday webinars this plan gets (e.g., 1 or 2)
  minPriceInr     Float    // UPDATED: Allows custom amounts
  minPriceUsd     Float
  
  subscriptions   UserSubscription[]
}

model UserSubscription {
  id                String   @id @default(uuid())
  userId            String   @unique 
  planId            String
  orderId           String   @unique 
  remainingCredits  Int      @default(0) // NEW: Deducted when they claim a Sunday webinar
  startDate         DateTime @default(now())
  expiryDate        DateTime 
  isActive          Boolean  @default(true)

  user              User             @relation(fields: [userId], references: [id])
  plan              SubscriptionPlan @relation(fields: [planId], references: [id])
}

// -----------------------------------------------------------------------------
// 5. BLOGS
// -----------------------------------------------------------------------------
model Blog {
  id           String   @id @default(uuid())
  slug         String   @unique
  title        String
  category     String   @default("Spirituality") 
  excerpt      String?  @db.Text
  body         Json     // Stores the bodyBlock array exactly as frontend sends it
  image        String?  // Renamed from imageUrl to match frontend
  youtubeUrl   String?
  author       String
  authorAvatar String?
  date         String?
  readTime     String
  isPublished  Boolean  @default(true)
  featured     Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// -----------------------------------------------------------------------------
// 6. FINANCIAL TRANSACTIONS (Razorpay Ledger)
// -----------------------------------------------------------------------------
model Order {
  id                String      @id @default(uuid())
  userId            String
  razorpayOrderId   String      @unique
  razorpayPaymentId String?     @unique 
  amount            Float
  currency          String   
  status            OrderStatus @default(PENDING)
  itemType          ItemType    
  itemId            String      
  couponId          String?
  coupon            Coupon?     @relation(fields: [couponId], references: [id])
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  user              User        @relation(fields: [userId], references: [id])
}

enum OrderStatus {
  PENDING
  SUCCESS
  FAILED
}

enum ItemType {
  COURSE
  WEBINAR
  SUBSCRIPTION
  RETREAT
}

// -----------------------------------------------------------------------------
// 7. RETREATS & APPLICATIONS
// -----------------------------------------------------------------------------

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
  PAID
}

model Retreat {
  id          String   @id @default(uuid())
  title       String
  description String
  location    String
  startDate   DateTime
  endDate     DateTime
  priceInr    Float
  imageUrl    String?  // 🚨 ADD THIS LINE!
  createdAt   DateTime @default(now())

  applications RetreatApplication[]
}

model RetreatApplication {
  id        String   @id @default(uuid())
  userId    String
  retreatId String
  
  // User Form Details
  name      String
  email     String
  phone     String
  
  // Tracking
  status    ApplicationStatus @default(PENDING)
  orderId   String?  @unique // Will link to Razorpay Order once approved & paid
  createdAt DateTime @default(now())

  // Relations
  user      User     @relation(fields: [userId], references: [id])
  retreat   Retreat  @relation(fields: [retreatId], references: [id])

  @@unique([userId, retreatId]) // A user can only apply once per retreat
}

// -----------------------------------------------------------------------------
// 8. COUPONS & DISCOUNTS
// -----------------------------------------------------------------------------

model GroupDiscountRequest {
  id          String   @id @default(uuid())
  userId      String   // The person organizing the group
  memberCount Int
  emails      String[] // Array of their friends' emails
  status      String   @default("PENDING") // PENDING, APPROVED, REJECTED
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id])
}

model Coupon {
  id              String    @id @default(uuid())
  code            String    @unique
  discountPercent Float
  maxUses         Int
  usedCount       Int       @default(0)
  isActive        Boolean   @default(true)
  expiryDate      DateTime? 
  
  // ANTI-FRAUD FIELD: Only these specific emails can use this coupon
  allowedEmails   String[]  

  orders          Order[]
  createdAt       DateTime  @default(now())
}