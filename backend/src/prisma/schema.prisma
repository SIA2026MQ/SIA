// src/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// -----------------------------------------------------------------------------
// 1. USERS & AUTHENTICATION
// -----------------------------------------------------------------------------
model User {
  id                  String   @id @default(uuid())
  firebaseUid         String   @unique 
  email               String   @unique
  name                String
  passwordHash        String?  
  role                Role     @default(USER)
  
  level               Int      @default(1)

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  isBlocked           Boolean  @default(false)
  courseAccess        CourseAccess[]
  webinarAccess       WebinarAccess[]     
  subscription        UserSubscription?    
  orders              Order[]
  retreatApplications RetreatApplication[]
  groupRequests       GroupDiscountRequest[]
  videoProgress       VideoProgress[]
  attendances         DailySessionAttendance[]
}

enum Role {
  USER
  ADMIN
}

// -----------------------------------------------------------------------------
// 2. COURSES (Lifetime Access)
// -----------------------------------------------------------------------------

enum CourseCategory {
  Practices
  Scriptures
}

model Course {
  id            String         @id @default(uuid())
  title         String
  description   String         @db.Text
  category      CourseCategory 
  priceInr      Float  
  priceUsd      Float  
  thumbnailUrl  String?        
  duration      String?        
  rating        Float?         @default(5.0)
  isPublished   Boolean        @default(false)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  videos        CourseVideo[]
  accessLedger  CourseAccess[]
  progress      VideoProgress[] 
}

model CourseVideo {
  id            String   @id @default(uuid())
  courseId      String
  title         String
  description   String?  @db.Text
  videoUrlR2    String   
  orderIndex    Int      
  
  course        Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  progress      VideoProgress[] 
}

model CourseAccess {
  id            String   @id @default(uuid())
  userId        String
  courseId      String
  orderId       String   @unique 
  purchasedAt   DateTime @default(now())

  user          User     @relation(fields: [userId], references: [id])
  course        Course   @relation(fields: [courseId], references: [id])

  @@unique([userId, courseId]) 
}

// -----------------------------------------------------------------------------
// 3. WEBINARS (One-Time Access or Redeemed via Credits)
// -----------------------------------------------------------------------------
model Webinar {
  id            String   @id @default(uuid())
  title         String
  description   String?  @db.Text
  zoomLink      String   
  minPriceInr   Float    
  minPriceUsd   Float
  scheduledFor  DateTime
  imageUrl      String?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now()) @updatedAt 

  accessLedger  WebinarAccess[]
}

model WebinarAccess {
  id            String   @id @default(uuid())
  userId        String
  webinarId     String
  orderId       String?  @unique 
  purchasedAt   DateTime @default(now())

  user          User     @relation(fields: [userId], references: [id])
  webinar       Webinar  @relation(fields: [webinarId], references: [id])

  @@unique([userId, webinarId]) 
}

// -----------------------------------------------------------------------------
// 4. DAILY SESSIONS & SUBSCRIPTIONS (Credit-Based)
// -----------------------------------------------------------------------------
model DailySession {
  id          String   @id @default(uuid())
  title       String   @default("Live Session")
  zoomLink    String   
  time        String?  
  
  // 🚨 NEW: Distinguish between Satsung and QnA
  sessionType String   @default("Satsung") 
  
  // 🚨 NEW: Status Dropdown (Enable/Disable)
  isActive    Boolean  @default(false) 

  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt 
  attendances DailySessionAttendance[]
}

// 🚨 NEW: Schedule table for upcoming Satsungs and QnAs
model SatsangSchedule {
  id        String   @id @default(uuid())
  title     String
  category  String   @default("Satsung") // "Satsung" or "QnA"
  date      DateTime
  time      String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SubscriptionPlan {
  id              String   @id @default(uuid())
  name            String   
  durationDays    Int      
  webinarCredits  Int      
  minPriceInr     Float    
  minPriceUsd     Float
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now()) @updatedAt 

  subscriptions   UserSubscription[]
}

model UserSubscription {
  id                String   @id @default(uuid())
  userId            String   @unique 
  planId            String
  orderId           String   @unique 
  remainingCredits  Int      @default(0) 
  startDate         DateTime @default(now())
  expiryDate        DateTime 
  isActive          Boolean  @default(true)

  createdAt         DateTime @default(now())
  updatedAt         DateTime @default(now()) @updatedAt 

  user              User             @relation(fields: [userId], references: [id])
  plan              SubscriptionPlan @relation(fields: [planId], references: [id])
}

// -----------------------------------------------------------------------------
// 5. BLOGS
// -----------------------------------------------------------------------------
model Blog {
  id            String   @id @default(uuid())
  slug          String   @unique
  title         String
  category      String   @default("Spirituality") 
  excerpt       String?  @db.Text
  body          Json     
  image         String?  
  youtubeUrl    String?
  author        String
  authorAvatar  String?
  date          String?
  readTime      String
  isPublished   Boolean  @default(true)
  featured      Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// -----------------------------------------------------------------------------
// 6. FINANCIAL TRANSACTIONS (Razorpay Ledger)
// -----------------------------------------------------------------------------
model Order {
  id                String      @id @default(uuid())
  userId            String
  razorpayOrderId   String      @unique
  razorpayPaymentId String?     @unique 
  amount            Float
  currency          String   
  status            OrderStatus @default(PENDING)
  itemType          ItemType    
  itemId            String      
  couponId          String?
  coupon            Coupon?     @relation(fields: [couponId], references: [id])
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  user              User        @relation(fields: [userId], references: [id])
}

enum OrderStatus {
  PENDING
  SUCCESS
  FAILED
}

enum ItemType {
  COURSE
  WEBINAR
  SUBSCRIPTION
  RETREAT
}

// -----------------------------------------------------------------------------
// 7. RETREATS & APPLICATIONS
// -----------------------------------------------------------------------------

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
  PAID
}

model Retreat {
  id            String   @id @default(uuid())
  title         String
  description   String
  location      String
  startDate     DateTime
  endDate       DateTime
  priceInr      Float
  imageUrl      String?  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now()) @updatedAt 

  applications  RetreatApplication[]
}

model RetreatApplication {
  id        String   @id @default(uuid())
  userId    String
  retreatId String
  
  // User Form Details
  name      String
  email     String
  phone     String
  
  // Tracking
  status    ApplicationStatus @default(PENDING)
  orderId   String?  @unique 
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt 

  // Relations
  user      User     @relation(fields: [userId], references: [id])
  retreat   Retreat  @relation(fields: [retreatId], references: [id])

  @@unique([userId, retreatId]) 
}

// -----------------------------------------------------------------------------
// 8. COUPONS & DISCOUNTS
// -----------------------------------------------------------------------------

model GroupDiscountRequest {
  id          String   @id @default(uuid())
  userId      String   
  memberCount Int
  emails      String[] 
  status      String   @default("PENDING") 
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt 

  user        User     @relation(fields: [userId], references: [id])
}

model Coupon {
  id              String    @id @default(uuid())
  code            String    @unique
  discountPercent Float
  maxUses         Int
  usedCount       Int       @default(0)
  isActive        Boolean   @default(true)
  expiryDate      DateTime? 
  
  allowedEmails   String[]  

  orders          Order[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @default(now()) @updatedAt 
}

// -----------------------------------------------------------------------------
// 9. ATTENDANCE TRACKING
// -----------------------------------------------------------------------------
model DailySessionAttendance {
  id        String   @id @default(uuid())
  userId    String
  sessionId String
  joinedAt  DateTime @default(now())

  // 🚨 ADDED onDelete: Cascade to PREVENT 500 ERRORS WHEN DELETING A SESSION!
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  session   DailySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([userId, sessionId]) 
}

// -----------------------------------------------------------------------------
// 10. LEARNING PROGRESS TRACKING (Enterprise CRM Feature)
// -----------------------------------------------------------------------------
model VideoProgress {
  id        String   @id @default(uuid())
  userId    String
  courseId  String
  videoId   String
  createdAt DateTime @default(now())

  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  course    Course      @relation(fields: [courseId], references: [id], onDelete: Cascade)
  video     CourseVideo @relation(fields: [videoId], references: [id], onDelete: Cascade)
  
  @@unique([userId, videoId]) 
  
  @@index([userId])
  @@index([courseId])
}